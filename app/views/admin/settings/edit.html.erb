<h1 class="text-3xl font-bold mb-6">Paramètres globaux</h1>

<div class="bg-white rounded-lg shadow p-6">
  <%= form_with model: @setting, url: admin_settings_path, method: :patch, class: "space-y-6" do |f| %>
    <div>
      <%= f.label :claude_global_instructions, "Consignes globales pour Claude (toutes les URLs)", class: "block font-bold mb-2" %>
      <%= f.text_area :claude_global_instructions,
                      class: "w-full px-3 py-2 border rounded font-mono",
                      rows: 15,
                      placeholder: "Exemple:\n- Toujours extraire les dates au format ISO 8601\n- Si le prix n'est pas mentionné, mettre null\n- Détecter automatiquement les événements gratuits..." %>
      <p class="text-sm text-gray-600 mt-2">
        Ces consignes sont envoyées à Claude pour <strong>toutes les URLs scrapées</strong>.<br>
        Les "Notes correctrices" spécifiques à chaque URL sont ajoutées en plus de ces consignes globales.
      </p>
    </div>

    <div class="flex gap-4">
      <%= f.submit "Enregistrer", class: "bg-terracotta text-white px-6 py-2 rounded hover:bg-terracotta-dark cursor-pointer" %>
      <%= link_to "Retour", admin_path, class: "bg-gray-500 text-white px-6 py-2 rounded hover:bg-gray-600" %>
    </div>
  <% end %>
</div>
