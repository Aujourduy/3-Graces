<%# locals: event %>
<%= link_to evenement_path(event.slug),
            class: "block bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow p-4 mb-3",
            data: { turbo_frame: "event_modal", debug_id: "event-card-#{event.id}" } do %>

  <div class="flex gap-4">
    <%# Event photo (120x120 square - larger like Figma) %>
    <div class="flex-shrink-0">
      <% if event.photo_url.present? %>
        <%= image_tag event.photo_url,
                      alt: event.titre,
                      class: "w-28 h-28 object-cover rounded-lg",
                      loading: "lazy" %>
      <% else %>
        <%# Placeholder if no photo %>
        <div class="w-28 h-28 bg-terracotta-light rounded-lg flex items-center justify-center text-white text-3xl font-bold">
          <%= event.professor.nom&.first&.upcase || "?" %>
        </div>
      <% end %>
    </div>

    <%# Event details %>
    <div class="flex-grow min-w-0">
      <%# Type badge + Time - prominent like Figma %>
      <div class="flex items-center gap-2 mb-2">
        <%# Type badge - red for STAGE, blue for ATELIER %>
        <% if event.type_event == "stage" %>
          <span class="px-3 py-1 rounded text-xs font-bold bg-red-600 text-white uppercase">STAGE</span>
        <% else %>
          <span class="px-3 py-1 rounded text-xs font-bold bg-blue-600 text-white uppercase">ATELIER</span>
        <% end %>

        <%# Time %>
        <span class="text-gray-600 text-sm font-medium">
          <%= l(event.date_debut, format: :time_only) %>
        </span>
      </div>

      <%# Title - bold and prominent %>
      <h3 class="font-bold text-lg mb-2 line-clamp-2"><%= event.titre %></h3>

      <%# Presenter %>
      <p class="text-gray-700 text-sm mb-1 font-medium">
        Animé par <%= event.professor.nom %>
      </p>

      <%# Location %>
      <p class="text-gray-600 text-sm flex items-center gap-1 mb-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
        </svg>
        <%= event.lieu %>
      </p>

      <%# Additional tags (gratuit, en ligne, etc.) %>
      <div class="flex flex-wrap gap-2">
        <% if event.gratuit %>
          <span class="px-2 py-1 rounded text-xs font-medium bg-green-100 text-green-800">Gratuit</span>
        <% else %>
          <span class="px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-700">
            <%= number_to_currency(event.prix_normal, unit: "€", format: "%n%u") %>
          </span>
        <% end %>

        <% if event.en_ligne %>
          <span class="px-2 py-1 rounded text-xs font-medium bg-blue-100 text-blue-800">En ligne</span>
        <% end %>

        <% if event.en_presentiel %>
          <span class="px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-700">En présentiel</span>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
