# 3 Graces - Environment Variables Example
# Copy this file to .env and fill in with real values

# Database
DB_PASSWORD=change_me_in_production

# Admin credentials for HTTP Basic Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# Alert email for scraping failures
ALERT_EMAIL=admin@3graces.community

# Rails secret key (generate with: rails secret)
SECRET_KEY_BASE=change_me_run_rails_secret

# Claude CLI (optional - can authenticate interactively)
# ANTHROPIC_API_KEY=sk-ant-xxx
